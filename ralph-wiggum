#!/bin/bash

set -euo pipefail

CONFIG_DIR="$HOME/.config/ralph-wiggum"
IMAGE_NAME="ralph-wiggum"
IMAGE_NAME_OPENCODE="ralph-wiggum-opencode"
USERNAME=$(whoami)
USE_OPENCODE=0

do_init() {
    # Validate: must have a .git/ directory (not bare, not worktree)
    if [ ! -d ".git" ]; then
        echo "Error: no .git/ directory in $(pwd). Run from a regular git repo root."
        exit 1
    fi

    # Validate: clean working tree
    if [ -n "$(git status --porcelain)" ]; then
        echo "Error: working tree is not clean. Commit or stash changes first."
        exit 1
    fi

    # Validate: specs/features.md must exist
    if [ ! -f "specs/features.md" ]; then
        echo "Error: specs/features.md not found in $(pwd)"
        exit 1
    fi

    # If .bare/ already exists → error
    if [ -d ".bare" ]; then
        echo "Error: .bare/ already exists. Already initialized."
        exit 1
    fi

    # Convert to bare + worktree
    BRANCH=$(git rev-parse --abbrev-ref HEAD)
    mv .git .bare
    git --git-dir=.bare config core.bare true
    git --git-dir=.bare config --unset core.worktree 2>/dev/null || true
    git --git-dir="$(pwd)/.bare" worktree add main "$BRANCH"

    # Remove old working tree files from project root (everything except .bare/ and main/)
    for item in *; do
        [ "$item" = "main" ] && continue
        rm -rf "$item"
    done
    # Also remove dotfiles (except .bare)
    for item in .[!.]*; do
        [ "$item" = ".bare" ] && continue
        [ "$item" = "." ] && continue
        [ "$item" = ".." ] && continue
        rm -rf "$item"
    done

    # In main worktree: add .ralph-wiggum to .gitignore
    if [ -f main/.gitignore ]; then
        if ! grep -qxF '.ralph-wiggum' main/.gitignore; then
            echo '.ralph-wiggum' >> main/.gitignore
        fi
    else
        echo '.ralph-wiggum' > main/.gitignore
    fi
    git -C main add .gitignore
    git -C main commit -m "ralph: add .ralph-wiggum to .gitignore"

    # Create state directory
    mkdir -p main/.ralph-wiggum

    echo ""
    echo "Initialized. Your checkout is now at: $(pwd)/main/"
    echo "Run: cd main && ralph-wiggum 5"
}

run_docker() {
    local WORK_DIR="$1"
    local DIRNAME
    DIRNAME=$(basename "$WORK_DIR")
    local GIT_FILE="$WORK_DIR/.git"
    local GITDIR_FILE="$PROJECT_ROOT/.bare/worktrees/$DIRNAME/gitdir"

    # Rewrite git worktree paths so they resolve inside the container
    local ORIG_DOTGIT="" ORIG_GITDIR=""
    if [ -f "$GIT_FILE" ]; then
        ORIG_DOTGIT=$(cat "$GIT_FILE")
        echo "gitdir: /project/.bare/worktrees/$DIRNAME" > "$GIT_FILE"
    fi
    if [ -f "$GITDIR_FILE" ]; then
        ORIG_GITDIR=$(cat "$GITDIR_FILE")
        echo "/project/$DIRNAME" > "$GITDIR_FILE"
    fi

    local EXIT_CODE=0
    if [ "$USE_OPENCODE" -eq 1 ]; then
        docker run --rm \
            -v "$PROJECT_ROOT":/project \
            -w "/project/$DIRNAME" \
            -v "$CONFIG_DIR/ralph-wiggum.md":"/project/$DIRNAME/ralph-wiggum.md":ro \
            -v "$CONFIG_DIR/.opencode":/home/"$USERNAME"/.opencode \
            -e http_proxy \
            "$IMAGE_NAME_OPENCODE" || EXIT_CODE=$?
    else
        docker run --rm \
            -v "$PROJECT_ROOT":/project \
            -w "/project/$DIRNAME" \
            -v "$CONFIG_DIR/ralph-wiggum.md":"/project/$DIRNAME/ralph-wiggum.md":ro \
            -v "$CONFIG_DIR/.claude-for-linux":/home/"$USERNAME"/.claude \
            -e http_proxy \
            "$IMAGE_NAME" || EXIT_CODE=$?
    fi

    # Restore original git paths
    if [ -n "$ORIG_DOTGIT" ]; then
        echo "$ORIG_DOTGIT" > "$GIT_FILE"
    fi
    if [ -n "$ORIG_GITDIR" ]; then
        echo "$ORIG_GITDIR" > "$GITDIR_FILE"
    fi

    return "$EXIT_CODE"
}

do_run() {
    REBUILD=0
    REBUILD_OPENCODE=0
    ITERATIONS=1

    # Parse arguments
    for arg in "$@"; do
        case "$arg" in
            --rebuild)
                REBUILD=1
                ;;
            --opencode)
                USE_OPENCODE=1
                ;;
            --build-opencode)
                REBUILD_OPENCODE=1
                ;;
            *)
                if [[ "$arg" =~ ^[0-9]+$ ]]; then
                    ITERATIONS=$arg
                else
                    echo "Usage: ralph-wiggum [--rebuild] [--opencode] [--build-opencode] [iterations]"
                    echo "       ralph-wiggum init"
                    exit 1
                fi
                ;;
        esac
    done

    # Detect project root and main worktree
    if [ -d ".bare" ]; then
        PROJECT_ROOT=$(pwd)
        MAIN_DIR="$PROJECT_ROOT/main"
        if [ ! -d "$MAIN_DIR" ]; then
            echo "Error: main/ worktree not found. Run 'ralph-wiggum init' first."
            exit 1
        fi
        cd "$MAIN_DIR"
    elif [ -d "../.bare" ]; then
        PROJECT_ROOT=$(cd .. && pwd)
        MAIN_DIR=$(pwd)
    else
        echo "Error: .bare/ not found. Run 'ralph-wiggum init' from the project root first."
        exit 1
    fi

    # Validate specs/ exists in main worktree
    if [ ! -d "specs" ]; then
        echo "Error: no specs/ directory found in $(pwd)"
        exit 1
    fi

    mkdir -p "$MAIN_DIR/.ralph-wiggum"

    # Build opencode Docker image if --build-opencode or --opencode requested
    if [ "$REBUILD_OPENCODE" -eq 1 ] || [ "$USE_OPENCODE" -eq 1 ]; then
        if [ "$REBUILD_OPENCODE" -eq 1 ] || ! docker image inspect "$IMAGE_NAME_OPENCODE" > /dev/null 2>&1; then
            echo "Building Docker image '$IMAGE_NAME_OPENCODE'..."
            docker build \
                -f "$CONFIG_DIR/Dockerfile.opencode" \
                --build-arg USER_ID="$(id -u)" \
                --build-arg GROUP_ID="$(id -g)" \
                --build-arg USERNAME="$USERNAME" \
                -t "$IMAGE_NAME_OPENCODE" \
                "$CONFIG_DIR/"
            echo "Docker image '$IMAGE_NAME_OPENCODE' built."
        fi
    fi

    # Build claude Docker image if --rebuild or default (not --opencode)
    if [ "$REBUILD" -eq 1 ]; then
        echo "Building Docker image '$IMAGE_NAME'..."
        docker build \
            -f "$CONFIG_DIR/Dockerfile.claude" \
            --build-arg USER_ID="$(id -u)" \
            --build-arg GROUP_ID="$(id -g)" \
            --build-arg USERNAME="$USERNAME" \
            -t "$IMAGE_NAME" \
            "$CONFIG_DIR/"
        echo "Docker image '$IMAGE_NAME' built."
    elif [ "$USE_OPENCODE" -eq 0 ]; then
        # Only check for claude image if not using opencode
        if ! docker image inspect "$IMAGE_NAME" > /dev/null 2>&1; then
            echo "Building Docker image '$IMAGE_NAME'..."
            docker build \
                -f "$CONFIG_DIR/Dockerfile.claude" \
                --build-arg USER_ID="$(id -u)" \
                --build-arg GROUP_ID="$(id -g)" \
                --build-arg USERNAME="$USERNAME" \
                -t "$IMAGE_NAME" \
                "$CONFIG_DIR/"
            echo "Docker image '$IMAGE_NAME' built."
        fi
    fi

    # Run iterations
    echo "Starting Ralph Wiggum for $ITERATIONS iterations..."

    for i in $(seq 1 "$ITERATIONS"); do
        echo ""
        echo "================================================================"
        echo "  Ralph Wiggum - Run $i/$ITERATIONS"
        echo "================================================================"
        echo ""

        # Find active feature worktree (any worktree not on main/master)
        FEATURE_WORKTREE=""
        FEATURE_BRANCH=""
        while IFS= read -r line; do
            wt_path=$(echo "$line" | awk '{print $1}')
            wt_branch=$(echo "$line" | sed -n 's/.*\[\(.*\)\].*/\1/p')
            if [ -n "$wt_branch" ] && [ "$wt_branch" != "main" ] && [ "$wt_branch" != "master" ]; then
                FEATURE_WORKTREE="$wt_path"
                FEATURE_BRANCH="$wt_branch"
                break
            fi
        done < <(git worktree list)

        # If no active feature worktree, ask the LLM to pick the next feature
        if [ -z "$FEATURE_WORKTREE" ]; then
            NEXT_FEATURE_FILE="$MAIN_DIR/.ralph-wiggum/NEXT-FEATURE"

            # If LLM hasn't picked the next feature yet, ask it to
            if [ ! -f "$NEXT_FEATURE_FILE" ]; then
                echo "No active feature. Asking LLM to pick the next one..."
                touch "$MAIN_DIR/.ralph-wiggum/PICK-NEXT-FEATURE"

                run_docker "$MAIN_DIR"

                rm -f "$MAIN_DIR/.ralph-wiggum/PICK-NEXT-FEATURE"
            fi

            # Read what the LLM picked
            if [ ! -f "$NEXT_FEATURE_FILE" ]; then
                echo "LLM did not write NEXT-FEATURE. All features may be complete, or something went wrong."
                exit 1
            fi

            SLUG=$(sed -n '1p' "$NEXT_FEATURE_FILE")
            FEATURE_ID=$(sed -n '2p' "$NEXT_FEATURE_FILE")

            if [ -z "$SLUG" ]; then
                echo "Error: NEXT-FEATURE file has no slug on line 1."
                exit 1
            fi

            FEATURE_BRANCH="$SLUG"
            FEATURE_WORKTREE="$PROJECT_ROOT/$SLUG"

            echo "Creating worktree for feature: $SLUG (id: $FEATURE_ID)"

            # Create branch from main and worktree
            git branch "$SLUG" HEAD
            git worktree add "$FEATURE_WORKTREE" "$SLUG"

            # Seed .ralph-wiggum in the new worktree
            mkdir -p "$FEATURE_WORKTREE/.ralph-wiggum"

            # Copy completed.txt so the LLM knows history
            if [ -f "$MAIN_DIR/.ralph-wiggum/completed.txt" ]; then
                cp "$MAIN_DIR/.ralph-wiggum/completed.txt" "$FEATURE_WORKTREE/.ralph-wiggum/completed.txt"
            fi

            rm -f "$NEXT_FEATURE_FILE"

            # This iteration was used for feature selection; continue to next
            echo "Feature worktree created. Continuing to next iteration..."
            sleep 2
            continue
        fi

        echo "Working in: $FEATURE_WORKTREE (branch: $FEATURE_BRANCH)"

        run_docker "$FEATURE_WORKTREE"

        echo ""
        echo "Run $i completed"

        # Check if feature is complete
        if [ -f "$FEATURE_WORKTREE/.ralph-wiggum/COMPLETE" ]; then
            echo ""
            echo "Feature complete! Merging $FEATURE_BRANCH into main..."

            # Merge into main (fail loudly on conflict)
            git -C "$MAIN_DIR" merge --no-ff "$FEATURE_BRANCH"

            # Record completed feature — store the COMPLETE file contents
            cat "$FEATURE_WORKTREE/.ralph-wiggum/COMPLETE" >> "$MAIN_DIR/.ralph-wiggum/completed.txt"
            echo "" >> "$MAIN_DIR/.ralph-wiggum/completed.txt"

            # Remove worktree and branch
            git worktree remove --force "$FEATURE_WORKTREE" 2>/dev/null \
                || { rm -rf "$FEATURE_WORKTREE"; git worktree prune; }
            git branch -d "$FEATURE_BRANCH"

            echo "Merged and cleaned up worktree for $FEATURE_BRANCH"
        fi

        if [ "$i" -lt "$ITERATIONS" ]; then
            sleep 2
        fi
    done

    echo ""
    echo "================================================================"
    echo "  Ralph Wiggum completed $ITERATIONS iterations"
    echo "================================================================"
}

case "${1:-}" in
    init)   do_init ;;
    *)      do_run "$@" ;;
esac
